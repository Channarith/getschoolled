# Local deployment contract (docker compose / single machine).
# The SAME code reads these; switch to config/cloud.env for cloud.

DEPLOY_MODE=local

# Per-component overrides (leave blank to inherit DEPLOY_MODE).
LLM_MODE=
SPEECH_MODE=
VISION_MODE=
MEDIA_MODE=
OBJECT_STORE_MODE=
PAYMENT_MODE=

# Endpoints (compose service names).
LLM_BASE_URL=http://vllm:8000/v1
LLM_MODEL=education-base
# Track B per-domain routing (category=model,...) for RoutedLLMProvider. Empty = single model.
LLM_ROUTES=
# 24/7 harvester (runs on a separate worker agent)
HARVEST_USER_AGENT="AOEP-Harvester/1.0 (+contact@example.org)"
HARVEST_MAX_RPS=1.0
HARVEST_SEEDS=
LIVEKIT_URL=ws://livekit:7880
DATABASE_URL=postgresql://edu:edu@postgres:5432/edu
REDIS_URL=redis://redis:6379/0
OBJECT_STORE_ENDPOINT=http://minio:9000
OBJECT_STORE_BUCKET=edu-media

# Curriculum source for the RAG skeleton.
CURRICULUM_DIR=/app/sample-curriculum

# Web -> orchestrator (browser-visible).
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000

# Catalog + corrections persistence (blank => in-memory).
CATALOG_PATH=
CORRECTIONS_JSONL=training/data/corrections.jsonl

# Course-validation search engine keys (blank => offline mock engine).
BING_SEARCH_KEY=
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=
BRAVE_SEARCH_KEY=
KAGI_API_KEY=
BAIDU_API_KEY=
# Bake-off champion pointer (written by training/bakeoff.py --champion-path)
CHAMPION_PATH=
# Content-credentials/provenance signing key (Trust layer)
PROVENANCE_SIGNING_KEY=
# OCR (homework scanning; handwriting needs a cloud OCR backend)
OCR_MODE=
OCR_API_KEY=
OCR_ENDPOINT=
# Human-in-the-loop autonomy: autonomous | suggest | human_led
HIL_AUTONOMY=autonomous
# Embodiment: screen | robot (humanoid)
EMBODIMENT=screen
ROBOT_ENDPOINT=
# Integrations: webhook signing + inbound verification
WEBHOOK_SIGNING_KEY=
# Compliance region for the policy engine: us | us_il | eu | other
REGION=us
# Careers / jobs source. Off by default locally (serves the curated sample board
# offline, no network). Set JOBS_LIVE=1 to pull real openings from public boards
# (Remotive + Arbeitnow), or RAPIDAPI_KEY (JSearch: LinkedIn/Indeed/Glassdoor) /
# ADZUNA_APP_ID+ADZUNA_APP_KEY for keyed aggregators. Falls back to sample if
# the network is unavailable. JOBS_PROVIDER can pin one (remotive|arbeitnow|
# jsearch|adzuna|linkedin|sample|live).
JOBS_LIVE=
JOBS_PROVIDER=
RAPIDAPI_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Identity: session-token signing key (set a strong secret in production)
AUTH_SIGNING_KEY=
# Default admin account, seeded at identity startup so you can log in out of the
# box. Log in with the email OR the bare username. CHANGE the password for any
# real deployment. Disable seeding with SEED_DEFAULT_ADMIN=0.
SEED_DEFAULT_ADMIN=1
DEFAULT_ADMIN_EMAIL=admin@salareen.com
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=88888888
# QA test accounts (3 personas for manual/release testing). Log in with email or
# qa1 / qa2 / qa3. Disable seeding with SEED_QA_ACCOUNTS=0.
SEED_QA_ACCOUNTS=1
QA_ACCOUNTS_PASSWORD=QaTest123
# Admin: secret that gates administrative feature-flag writes (X-Admin-Secret
# header). Defaults to a dev value when unset; set a strong secret in production.
ADMIN_SECRET=
# Automation/E2E test hooks (deterministic reset/seed). Implicitly on for local/
# edge, off for cloud; set to 1/0 to force. Always also requires the admin secret.
ENABLE_TEST_ENDPOINTS=
# Observability: every service exposes /metrics (Prometheus) + /telemetry/* with
# zero deps. Optional external export (only used if the lib is installed):
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
OTEL_EXPORTER_OTLP_ENDPOINT=
