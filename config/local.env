# AOEP - LOCAL deployment contract (docker compose, single machine / on-prem).
# Same codebase as cloud; only these values differ. Override any single
# component with <COMPONENT>_MODE without forking code.

DEPLOY_MODE=local

# Per-component overrides (default to DEPLOY_MODE when unset). Biometrics can be
# pinned local even in a cloud deployment for compliance.
# LLM_MODE=local
# SPEECH_MODE=local
# VISION_MODE=local
# MEDIA_MODE=local
# OBJECT_STORE_MODE=local
# PAYMENT_MODE=local
# DATABASE_MODE=local
# BUS_MODE=local

# LLM (self-hosted vLLM/Ollama, OpenAI-compatible)
LLM_BASE_URL=http://llm:8000/v1
LLM_MODEL=aoep-base-edu

# Speech / Vision gateways
SPEECH_BASE_URL=http://speech:8100
VISION_BASE_URL=http://perception:8200

# Media (self-hosted LiveKit container)
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Object store (MinIO)
OBJECT_STORE_ENDPOINT=http://minio:9000
OBJECT_STORE_BUCKET=aoep
OBJECT_STORE_ACCESS_KEY=aoep
OBJECT_STORE_SECRET_KEY=aoep-secret

# Data stores
DATABASE_URL=postgresql://aoep:aoep@postgres:5432/aoep
REDIS_URL=redis://redis:6379/0

# Payments (sandbox stub; no key needed locally)
PAYMENT_API_KEY=

# Curriculum corpus mounted into the curriculum service
CURRICULUM_DIR=/app/sample-curriculum

# Web -> orchestrator
ORCHESTRATOR_URL=http://localhost:8000
