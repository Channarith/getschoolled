# AOEP - CLOUD deployment contract (Kubernetes + GPU pool).
# Same codebase as local; only these values differ. Secrets shown here are
# placeholders -- inject real values via the cluster secret manager.

DEPLOY_MODE=cloud

# Per-component overrides. Example: keep biometrics inside a private boundary
# while everything else runs in the managed cloud.
# VISION_MODE=local

# LLM (managed vLLM/Triton or hosted OpenAI-compatible endpoint)
LLM_BASE_URL=https://llm.aoep.internal/v1
LLM_MODEL=aoep-base-edu

# Speech / Vision GPU pods
SPEECH_BASE_URL=https://speech.aoep.internal
VISION_BASE_URL=https://perception.aoep.internal

# Media (LiveKit cluster)
LIVEKIT_URL=wss://livekit.aoep.example
LIVEKIT_API_KEY=__INJECT_VIA_SECRET__
LIVEKIT_API_SECRET=__INJECT_VIA_SECRET__

# Object store (S3-compatible)
OBJECT_STORE_ENDPOINT=https://s3.amazonaws.com
OBJECT_STORE_BUCKET=aoep-prod
OBJECT_STORE_ACCESS_KEY=__INJECT_VIA_SECRET__
OBJECT_STORE_SECRET_KEY=__INJECT_VIA_SECRET__

# Managed Postgres (+pgvector) and Redis
DATABASE_URL=postgresql://aoep:__INJECT_VIA_SECRET__@postgres.aoep.internal:5432/aoep
REDIS_URL=redis://redis.aoep.internal:6379/0

# Payments (Stripe)
PAYMENT_API_KEY=__INJECT_VIA_SECRET__

# Curriculum corpus (object-store mount / sync)
CURRICULUM_DIR=/app/sample-curriculum

# Web -> orchestrator (ingress)
ORCHESTRATOR_URL=https://api.aoep.example
