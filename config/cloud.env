# Cloud deployment contract (Kubernetes + GPU pool).
# Same code as local; only this env differs. Secrets are injected by the
# platform (never committed): LLM/STRIPE/LIVEKIT/DB credentials, etc.

DEPLOY_MODE=cloud

# Compliance lever example: keep biometrics local even in cloud.
# VISION_MODE=local
LLM_MODE=
SPEECH_MODE=
VISION_MODE=
MEDIA_MODE=
OBJECT_STORE_MODE=
PAYMENT_MODE=

LLM_BASE_URL=https://llm.internal/v1
LLM_MODEL=education-base
# Track B per-domain routing (category=model,...) for RoutedLLMProvider. Empty = single model.
LLM_ROUTES=
# 24/7 harvester (runs on a separate worker agent)
HARVEST_USER_AGENT=AOEP-Harvester/1.0 (+contact@example.org)
HARVEST_MAX_RPS=2.0
HARVEST_SEEDS=
LIVEKIT_URL=wss://livekit.example.com
DATABASE_URL=postgresql://edu:CHANGE_ME@db.internal:5432/edu
REDIS_URL=redis://redis.internal:6379/0
OBJECT_STORE_ENDPOINT=https://s3.amazonaws.com
OBJECT_STORE_BUCKET=edu-media-prod

CURRICULUM_DIR=/app/sample-curriculum
NEXT_PUBLIC_ORCHESTRATOR_URL=https://api.example.com

# Catalog + corrections persistence (object store / mounted path in cloud).
CATALOG_PATH=
CORRECTIONS_JSONL=

# Course-validation search engine keys (injected as secrets in cloud).
BING_SEARCH_KEY=
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=
BRAVE_SEARCH_KEY=
KAGI_API_KEY=
BAIDU_API_KEY=
# Bake-off champion pointer (written by training/bakeoff.py --champion-path)
CHAMPION_PATH=
# Content-credentials/provenance signing key (Trust layer)
PROVENANCE_SIGNING_KEY=
# OCR (homework scanning; handwriting needs a cloud OCR backend)
OCR_MODE=
OCR_API_KEY=
OCR_ENDPOINT=
# Human-in-the-loop autonomy: autonomous | suggest | human_led
HIL_AUTONOMY=autonomous
# Embodiment: screen | robot (humanoid)
EMBODIMENT=screen
ROBOT_ENDPOINT=
# Integrations: webhook signing + inbound verification
WEBHOOK_SIGNING_KEY=
# Compliance region for the policy engine: us | us_il | eu | other
REGION=us
# Careers / jobs: pull REAL openings from public job boards (Remotive + Arbeitnow;
# no key, falls back to the curated board if egress is blocked). For listings that
# index LinkedIn/Indeed/Glassdoor, set RAPIDAPI_KEY (JSearch) or ADZUNA_APP_ID +
# ADZUNA_APP_KEY and they take precedence. JOBS_PROVIDER can pin one explicitly.
JOBS_LIVE=1
JOBS_PROVIDER=
RAPIDAPI_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Identity: session-token signing key (set a strong secret in production)
AUTH_SIGNING_KEY=
# Default admin account seeded at identity startup (log in with the email OR the
# bare username). SECURITY: change DEFAULT_ADMIN_PASSWORD before exposing the
# service publicly, or set SEED_DEFAULT_ADMIN=0 and create the admin manually.
SEED_DEFAULT_ADMIN=1
DEFAULT_ADMIN_EMAIL=admin@salareen.com
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=88888888
# QA test accounts for manual/release testing (see docs/release-testing.txt).
SEED_QA_ACCOUNTS=1
QA_ACCOUNTS_PASSWORD=QaTest123
# Admin: secret that gates administrative feature-flag writes (X-Admin-Secret header)
ADMIN_SECRET=
# Automation/E2E test hooks: keep OFF in cloud unless a test run explicitly opts in.
ENABLE_TEST_ENDPOINTS=0
# Observability: /metrics (Prometheus) + /telemetry/* are always on. In cloud,
# point Prometheus at each service's /metrics; optionally export errors/traces:
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_EXPORTER_OTLP_ENDPOINT=
