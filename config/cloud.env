# Cloud deployment contract (Kubernetes + GPU pool).
# Same code as local; only this env differs. Secrets are injected by the
# platform (never committed): LLM/STRIPE/LIVEKIT/DB credentials, etc.

DEPLOY_MODE=cloud

# Compliance lever example: keep biometrics local even in cloud.
# VISION_MODE=local
LLM_MODE=
SPEECH_MODE=
VISION_MODE=
MEDIA_MODE=
OBJECT_STORE_MODE=
PAYMENT_MODE=

LLM_BASE_URL=https://llm.internal/v1
LLM_MODEL=education-base
LIVEKIT_URL=wss://livekit.example.com
DATABASE_URL=postgresql://edu:CHANGE_ME@db.internal:5432/edu
REDIS_URL=redis://redis.internal:6379/0
OBJECT_STORE_ENDPOINT=https://s3.amazonaws.com
OBJECT_STORE_BUCKET=edu-media-prod

CURRICULUM_DIR=/app/sample-curriculum
NEXT_PUBLIC_ORCHESTRATOR_URL=https://api.example.com

# Catalog + corrections persistence (object store / mounted path in cloud).
CATALOG_PATH=
CORRECTIONS_JSONL=

# Course-validation search engine keys (injected as secrets in cloud).
BING_SEARCH_KEY=
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=
BRAVE_SEARCH_KEY=
KAGI_API_KEY=
BAIDU_API_KEY=
