{
  "name": "aiclassroom-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "AI Classroom mobile app (Android + iOS) - teach & learn on the go, incl. audio-only Drive Mode.",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:android": "expo start --android",
    "start:ios": "expo start --ios",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "npm run build:android && npm run build:ios",
    "build:android": "expo export --platform android --output-dir dist/android",
    "build:ios": "expo export --platform ios --output-dir dist/ios",
    "native:prebuild:android": "expo prebuild --platform android --no-install --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "~51.0.0",
    "expo-constants": "~16.0.2",
    "expo-speech": "~12.0.2",
    "expo-status-bar": "~1.12.1",
    "expo-system-ui": "~3.0.7",
    "react": "18.2.0",
    "react-native": "0.74.5"
  },
  "devDependencies": {
    "@types/react": "~18.2.45",
    "typescript": "~5.3.3"
  }
}
