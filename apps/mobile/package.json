{
  "name": "aiclassroom-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "AI Classroom mobile app (Android + iOS) - teach & learn on the go, incl. audio-only Drive Mode.",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "export": "expo export --output-dir dist --platform all",
    "export:ios": "expo export --output-dir dist --platform ios",
    "export:android": "expo export --output-dir dist --platform android",
    "prebuild": "expo prebuild --no-install --platform all",
    "build:android": "eas build -p android --profile production --non-interactive",
    "build:ios": "eas build -p ios --profile production --non-interactive",
    "build:preview:android": "eas build -p android --profile preview --non-interactive",
    "build:preview:ios": "eas build -p ios --profile preview --non-interactive"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.2.3",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~51.0.39",
    "expo-av": "~14.0.7",
    "expo-constants": "~16.0.2",
    "expo-device": "~6.0.2",
    "expo-linking": "~6.3.1",
    "expo-localization": "~15.0.3",
    "expo-notifications": "~0.28.19",
    "expo-speech": "~12.0.2",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@types/react": "~18.2.45",
    "typescript": "~5.3.3"
  }
}
