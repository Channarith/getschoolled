{
  "expo": {
    "name": "Salareen",
    "slug": "aiclassroom",
    "scheme": "aiclassroom",
    "version": "0.4.5",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/salareen_icon_1024.png",
    "splash": {
      "image": "./assets/salareen_icon_1024.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b1020"
    },
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "notification": {
      "iosDisplayInForeground": true,
      "color": "#0ea5e9"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#0ea5e9"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Detect when you are driving so Salareen can offer hands-free Drive Mode."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Salareen uses the microphone for Drive Mode voice questions (Hey Sala assistant).",
          "speechRecognitionPermission": "Salareen uses speech recognition so you can ask questions hands-free in Drive Mode.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox",
            "com.google.android.tts"
          ]
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aiclassroom.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "remote-notification"
        ],
        "NSMicrophoneUsageDescription": "Used for Drive Mode voice questions and pronunciation practice.",
        "NSSpeechRecognitionUsageDescription": "Used so you can ask Sala questions hands-free while listening to classes.",
        "NSLocationWhenInUseUsageDescription": "Detect when you are driving so Salareen can offer hands-free Drive Mode.",
        "NSMotionUsageDescription": "Use device motion to improve driving detection while Drive Mode is enabled."
      }
    },
    "android": {
      "package": "com.aiclassroom.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/salareen_adaptive_fg_1024.png",
        "backgroundColor": "#0b1020"
      },
      "permissions": [
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACTIVITY_RECOGNITION"
      ]
    },
    "extra": {
      "deployMode": "cloud",
      "cloudBaseUrl": "https://www.salareen.com",
      "curriculumUrl": "http://localhost:8005",
      "identityUrl": "http://localhost:8008",
      "memoryUrl": "http://localhost:8004",
      "eas": {
        "projectId": "0525481d-f3ca-4ae1-9665-2a18b993d4e7"
      }
    },
    "owner": "cvanthin978"
  }
}
