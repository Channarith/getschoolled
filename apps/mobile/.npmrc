node-linker=hoisted
public-hoist-pattern[]=*
# Copy packages into apps/mobile/node_modules — Metro cannot resolve symlinks that
# escape the project root (e.g. ~/node_modules/.pnpm → blank Android red screen).
package-import-method=copy
# pnpm v11 skips linking node_modules when it thinks install is done (Mac no-op bug).
optimistic-repeat-install=false
