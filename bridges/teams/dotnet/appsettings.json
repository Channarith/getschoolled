{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "TeamsBridge": {
    "AppId": "${TEAMS_APP_ID}",
    "AppSecret": "${TEAMS_APP_SECRET}",
    "TenantId": "${TEAMS_TENANT_ID}",
    "MediaCertificateThumbprint": "${TEAMS_MEDIA_CERT_THUMBPRINT}",
    "ServiceFqdn": "${TEAMS_BRIDGE_FQDN}"
  }
}
